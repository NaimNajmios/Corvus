sdk.dir=/path/to/android/sdk

# API Keys - Copy this file to local.properties and fill in your keys
# DO NOT commit local.properties - it is gitignored
#
# Get your free API keys from:
# - Google Fact Check: https://developers.google.com/fact-check/tools-api
# - Tavily: https://tavily.com
# - Gemini (Google AI): https://aistudio.google.com/app/apikey
# - Groq: https://console.groq.com/keys

GOOGLE_FACT_CHECK_API_KEY=your_google_fact_check_key_here
TAVILY_API_KEY=your_tavily_key_here
GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY=your_groq_key_here
